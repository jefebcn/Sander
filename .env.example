# ─── Database ─────────────────────────────────────────────────────────────────
#
# Option A — Neon (recommended for Vercel, free tier at neon.tech)
#   The app auto-detects .neon.tech URLs and uses the serverless HTTP adapter.
#   Get your URL from: https://console.neon.tech → your project → Connection string
#
# DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/sander?sslmode=require"
#
# Option B — Local PostgreSQL (Docker Compose, Supabase local, etc.)
#   Uses standard pg Pool adapter. Connection pooler (PgBouncer) recommended for production.
#
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sander_db"
#
# Option C — Supabase (free tier at supabase.com)
#   Use the "Session Mode" pooler URL (port 5432) for best compatibility.
#
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

DATABASE_URL="postgresql://user:password@localhost:5432/sander_db"

# ─── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"

# REQUIRED for custom domains / reverse proxies — must match the public-facing URL.
# Without this, NextAuth may generate wrong callback URLs (http:// vs https://)
# causing a redirect_uri_mismatch error from Google.
AUTH_URL="https://www.sanderbv.it"

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to whitelist: https://www.sanderbv.it/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── Email (password reset) ───────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3000 emails/month
# Add & verify your domain in the Resend dashboard, then set EMAIL_FROM.
# Without RESEND_API_KEY the app falls back to console.log (dev only).
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Sander <noreply@yourdomain.com>"
# Public URL used in email links — set to your Vercel deployment URL
APP_URL="https://your-app.vercel.app"
