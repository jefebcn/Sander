generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PlayerRole {
  BLOCKER
  DEFENDER
}

enum TournamentType {
  KING_OF_THE_BEACH
  BRACKETS
}

enum TournamentStatus {
  DRAFT
  LIVE
  COMPLETED
}

enum SessionStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

enum SessionFormat {
  TWO_VS_TWO
  THREE_VS_THREE
  FOUR_VS_FOUR
}

enum RatingType {
  SUPER
  TOP
  FLOP
}

// ─── Auth Models (NextAuth v5) ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts    Account[]
  authSessions AuthSession[]
  player      Player?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Player ───────────────────────────────────────────────────────────────────

model Player {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String
  preferredRole PlayerRole @default(DEFENDER)
  avatarUrl     String?

  // Auth link (optional — existing players created before auth won't have this)
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Tournament aggregate stats
  matchesWon     Int @default(0)
  matchesLost    Int @default(0)
  tournamentsWon Int @default(0)
  winRatePct     Int @default(0)

  // Level & XP
  level Int @default(1)
  xp    Int @default(0)

  // Social rating (raw vote counts; avgRating derived)
  superVotes Int @default(0)
  topVotes   Int @default(0)
  flopVotes  Int @default(0)
  // Stored 0–50: (super*50 + top*30) / max(1, total) → display as (v/10).toFixed(1)
  avgRating  Int @default(0)

  // Session stats
  sessionsPlayed Int @default(0)

  // Relations
  registrations       TournamentRegistration[]
  matchPlayers        MatchPlayer[]
  standings           TournamentStanding[]
  organizedSessions   Session[]
  sessionParticipants SessionParticipant[]
  ratingsGiven        PlayerRating[] @relation("Rater")
  ratingsReceived     PlayerRating[] @relation("Rated")

  @@map("players")
}

// ─── Tournament ───────────────────────────────────────────────────────────────

model Tournament {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name   String
  date   DateTime
  type   TournamentType
  status TournamentStatus @default(DRAFT)

  kotbTotalRounds Int?

  registrations TournamentRegistration[]
  matches       Match[]
  standings     TournamentStanding[]

  @@map("tournaments")
}

model TournamentRegistration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  tournamentId String
  playerId     String
  seedPosition Int?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@map("tournament_registrations")
}

model Match {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  round       Int
  matchNumber Int
  courtLabel  String?

  teamAScore Int?
  teamBScore Int?

  nextMatchId   String?
  nextMatchSlot Int?

  isCompleted Boolean @default(false)
  isBye       Boolean @default(false)

  players MatchPlayer[]

  @@map("matches")
}

model MatchPlayer {
  id      String @id @default(cuid())
  matchId String
  team    Int

  playerId String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@map("match_players")
}

model TournamentStanding {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt

  tournamentId String
  playerId     String

  points        Int @default(0)
  matchesWon    Int @default(0)
  matchesLost   Int @default(0)
  pointsFor     Int @default(0)
  pointsAgainst Int @default(0)
  rank          Int @default(0)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@map("tournament_standings")
}

// ─── Sessions ─────────────────────────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizerId String
  organizer   Player @relation(fields: [organizerId], references: [id])

  title      String
  location   String
  date       DateTime
  format     SessionFormat @default(TWO_VS_TWO)
  maxPlayers Int
  courtCost  Int?
  notes      String?

  status SessionStatus @default(OPEN)

  participants SessionParticipant[]
  ratings      PlayerRating[]

  @@map("sessions")
}

model SessionParticipant {
  id        String @id @default(cuid())
  sessionId String
  playerId  String
  team      Int?   // null=unassigned, 0=Team A, 1=Team B

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([sessionId, playerId])
  @@map("session_participants")
}

model PlayerRating {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  sessionId String
  raterId   String
  ratedId   String
  type      RatingType

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  rater   Player  @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)
  rated   Player  @relation("Rated", fields: [ratedId], references: [id], onDelete: Cascade)

  @@unique([sessionId, raterId, ratedId])
  @@map("player_ratings")
}
