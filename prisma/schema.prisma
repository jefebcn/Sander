generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PlayerRole {
  BLOCKER
  DEFENDER
}

enum TournamentType {
  KING_OF_THE_BEACH
  BRACKETS
  ROUND_ROBIN
  DOUBLE_ELIMINATION
  CHICECE
}

enum TournamentStatus {
  DRAFT
  LIVE
  COMPLETED
}

enum SessionStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

enum SessionFormat {
  TWO_VS_TWO
  THREE_VS_THREE
  FOUR_VS_FOUR
}

enum RatingType {
  SUPER
  TOP
  FLOP
}

enum BadgeType {
  MURO_IMPENETRABILE
  DIFESA_ACROBATICA
  LEADER_CARISMATICO
  SCHIACCIATA_POTENTE
  SERVIZIO_PRECISO
  SPIRITO_DI_SQUADRA
  MVP_PARTITA
  FAIR_PLAY
}

enum PaymentStatus {
  FREE
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

// ─── Auth Models (NextAuth v5) ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  password     String?   // null for OAuth-only users

  // Invite tracking
  invitedByPlayerId String?
  invitedByPlayer   Player?  @relation("PlayerInvites", fields: [invitedByPlayerId], references: [id])

  accounts    Account[]
  authSessions AuthSession[]
  player      Player?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Player ───────────────────────────────────────────────────────────────────

model Player {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String
  firstName     String?
  lastName      String?
  birthDate     DateTime?
  gender        String?
  nationality   String?
  preferredRole PlayerRole @default(DEFENDER)
  avatarUrl     String?

  // Auth link (optional — existing players created before auth won't have this)
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Tournament aggregate stats
  matchesWon     Int @default(0)
  matchesLost    Int @default(0)
  tournamentsWon Int @default(0)
  winRatePct     Int @default(0)

  // Level & XP
  level Int @default(1)
  xp    Int @default(0)

  // Glicko-2 skill rating (initial values per algorithm spec)
  glickoRating     Float @default(1500)
  glickoRD         Float @default(350)
  glickoVolatility Float @default(0.06)

  // Social rating (raw vote counts; avgRating derived)
  superVotes Int @default(0)
  topVotes   Int @default(0)
  flopVotes  Int @default(0)
  // Stored 0–50: (super*50 + top*30) / max(1, total) → display as (v/10).toFixed(1)
  avgRating  Int @default(0)

  // Session stats
  sessionsPlayed Int @default(0)

  // Stat distribution (must sum to 100; default = equal split)
  attPct Int @default(17)
  difPct Int @default(17)
  murPct Int @default(17)
  alzPct Int @default(17)
  ricPct Int @default(16)
  staPct Int @default(16)

  // Relations
  registrations        TournamentRegistration[]
  matchPlayers         MatchPlayer[]
  standings            TournamentStanding[]
  organizedSessions    Session[]
  sessionParticipants  SessionParticipant[]
  sessionMatchPlayers  SessionMatchPlayer[]
  ratingsGiven         PlayerRating[]     @relation("Rater")
  ratingsReceived      PlayerRating[]     @relation("Rated")
  badgesGiven          BadgeAward[]       @relation("BadgeGiver")
  badgesReceived       BadgeAward[]       @relation("BadgeReceiver")
  pushSubscriptions    PushSubscription[]
  notifications        Notification[]
  monthlyAwards        MonthlyAward[]
  videoSubmissions     VideoSubmission[]
  ratingHistory        RatingHistory[]
  invitedUsers         User[]             @relation("PlayerInvites")

  @@map("players")
}

// ─── Tournament ───────────────────────────────────────────────────────────────

model Tournament {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name   String
  date   DateTime
  type   TournamentType
  status TournamentStatus @default(DRAFT)

  kotbTotalRounds   Int?
  numCourts         Int @default(2)
  chiceceMatchCount Int @default(4)
  chicecePhase      String @default("GROUP")

  // Registration & payments
  location              String?
  description           String?
  registrationDeadline  DateTime?
  prizePool             String?
  priceCents            Int?          // null = free
  priceCurrency         String        @default("EUR")
  isOpenForRegistration Boolean       @default(false)

  registrations TournamentRegistration[]
  matches       Match[]
  standings     TournamentStanding[]

  @@map("tournaments")
}

model TournamentRegistration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  tournamentId         String
  playerId             String
  seedPosition         Int?
  teamName             String?
  teamLogoUrl          String?
  chicecePlusMinus     Int @default(0)
  chiceceMatchesPlayed Int @default(0)

  // Payment tracking
  paymentStatus         PaymentStatus @default(FREE)
  paymentMethod         String?       // "STRIPE" | "CASH" | "FREE"
  paidAt                DateTime?
  amountPaidCents       Int?
  stripeSessionId       String?       @unique
  stripePaymentIntentId String?       @unique
  adminNotes            String?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@index([tournamentId, paymentStatus])
  @@map("tournament_registrations")
}

model StripeWebhookEvent {
  id         String   @id                // Stripe event.id
  type       String
  receivedAt DateTime @default(now())
  payload    Json

  @@map("stripe_webhook_events")
}

model Match {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  round         Int
  matchNumber   Int
  bracketSection String @default("WB")   // "WB" | "LB" | "GF"
  courtLabel    String?

  // For DOUBLE_ELIMINATION: loser drops to LB instead of being eliminated
  loserNextMatchId   String?
  loserNextMatchSlot Int?

  teamAScore Int?
  teamBScore Int?

  nextMatchId   String?
  nextMatchSlot Int?

  isCompleted Boolean @default(false)
  isBye       Boolean @default(false)

  players MatchPlayer[]

  @@map("matches")
}

model MatchPlayer {
  id      String @id @default(cuid())
  matchId String
  team    Int

  playerId String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@map("match_players")
}

model TournamentStanding {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt

  tournamentId String
  playerId     String

  points        Int @default(0)
  matchesWon    Int @default(0)
  matchesLost   Int @default(0)
  pointsFor     Int @default(0)
  pointsAgainst Int @default(0)
  rank          Int @default(0)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@map("tournament_standings")
}

// ─── Sessions ─────────────────────────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizerId String
  organizer   Player @relation(fields: [organizerId], references: [id])

  title      String
  location   String
  date       DateTime
  format     SessionFormat @default(TWO_VS_TWO)
  maxPlayers Int
  courtCost  Int?
  notes      String?

  // Payment
  paymentType String  @default("FREE")  // "FREE" | "QUOTA" | "LOSER_PAYS"
  quotaAmount Int?                       // cents, per-person fixed quota
  loserPays   String?                    // e.g. "1 birra", "una cena"

  status    SessionStatus @default(OPEN)
  matchMode Boolean       @default(false)

  participants   SessionParticipant[]
  ratings        PlayerRating[]
  badgeAwards    BadgeAward[]
  sets           SessionSet[]
  sessionMatches SessionMatch[]

  @@map("sessions")
}

model SessionMatch {
  id          String  @id @default(cuid())
  sessionId   String
  round       Int
  matchNumber Int
  teamAScore  Int?
  teamBScore  Int?
  isCompleted Boolean @default(false)

  session Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  players SessionMatchPlayer[]

  @@map("session_matches")
}

model SessionMatchPlayer {
  id       String @id @default(cuid())
  matchId  String
  playerId String
  team     Int    // 0 = Team A, 1 = Team B

  match  SessionMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@map("session_match_players")
}

model SessionSet {
  id         String  @id @default(cuid())
  sessionId  String
  setNumber  Int
  teamAScore Int
  teamBScore Int
  session    Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_sets")
}

model SessionParticipant {
  id        String @id @default(cuid())
  sessionId String
  playerId  String
  team      Int?   // null=unassigned, 0=Team A, 1=Team B

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([sessionId, playerId])
  @@map("session_participants")
}

model PlayerRating {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  sessionId String
  raterId   String
  ratedId   String
  type      RatingType

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  rater   Player  @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)
  rated   Player  @relation("Rated", fields: [ratedId], references: [id], onDelete: Cascade)

  @@unique([sessionId, raterId, ratedId])
  @@map("player_ratings")
}

model RatingHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  rating     Float
  rd         Float
  source     String  // "tournament" | "session"
  sourceId   String  // tournament or session id

  @@map("rating_history")
}

model PushSubscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  playerId String
  endpoint String @unique
  p256dh   String
  auth     String

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model Notification {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  playerId  String
  title     String
  body      String
  url       String?
  readAt    DateTime?

  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@map("notifications")
}

model VideoSubmission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  blobUrl   String
  status    String   @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  note      String?  // admin rejection note

  reviewedAt DateTime?

  @@map("video_submissions")
}

model BadgeAward {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  sessionId  String
  giverId    String
  receiverId String
  badge      BadgeType

  session  Session @relation(fields: [sessionId],  references: [id], onDelete: Cascade)
  giver    Player  @relation("BadgeGiver",    fields: [giverId],    references: [id], onDelete: Cascade)
  receiver Player  @relation("BadgeReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([sessionId, giverId, receiverId, badge])
  @@map("badge_awards")
}

// ─── Monthly Podium Awards ────────────────────────────────────────────────────

model MonthlyAward {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  position  Int      // 1, 2, o 3
  month     Int      // 1–12
  year      Int      // es. 2026

  @@unique([playerId, month, year])
  @@unique([position, month, year])
  @@map("monthly_awards")
}
