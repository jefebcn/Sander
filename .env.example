# ─── Database ─────────────────────────────────────────────────────────────────
#
# Option A — Neon (recommended for Vercel, free tier at neon.tech)
#   The app auto-detects .neon.tech URLs and uses the serverless HTTP adapter.
#   Get your URL from: https://console.neon.tech → your project → Connection string
#
# DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/sander?sslmode=require"
#
# Option B — Local PostgreSQL (Docker Compose, Supabase local, etc.)
#   Uses standard pg Pool adapter. Connection pooler (PgBouncer) recommended for production.
#
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sander_db"
#
# Option C — Supabase (free tier at supabase.com)
#   Use the "Session Mode" pooler URL (port 5432) for best compatibility.
#
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

DATABASE_URL="postgresql://user:password@localhost:5432/sander_db"
